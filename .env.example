# Copy to .env and fill in. Loaded by docker-compose and the Makefile targets.
# Anything prefixed TS_ is also picked up by the in-process config loader.

TS_ENV=dev

# Postgres
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading
TS_POSTGRES_PASSWORD=trading

# Redis
TS_REDIS_ADDR=localhost:6379

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
TS_CLICKHOUSE_ADDR=localhost:9000

# NATS
TS_NATS_URL=nats://localhost:4222

# Observability
TS_OBSERVABILITY_METRICS_ADDR=:9090
